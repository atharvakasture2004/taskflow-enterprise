{
  "$id": "https://taskflow.local/identity.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TaskFlow User",
  "type": "object",
  "properties": {
    "traits": {
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email"
        },
        "name": {
          "type": "string"
        }
      },
      "required": ["email"],
      "additionalProperties": false
    }
  }
}